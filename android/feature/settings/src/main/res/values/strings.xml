    <string name="settings_subscription_faq_title">Preguntas frecuentes</string>
    <string name="settings_subscription_faq_cancel_question">¿Puedo cancelar en cualquier momento?</string>
    <string name="settings_subscription_faq_cancel_answer_web">Sí, podés cancelar tu suscripción cuando quieras. Como te suscribiste desde la web, ingresá a solennix.com &gt; Configuración &gt; Suscripción.</string>
    <string name="settings_subscription_faq_cancel_answer_ios">Sí, podés cancelar tu suscripción cuando quieras. Como te suscribiste desde iOS, abrí Configuración &gt; tu Apple ID &gt; Suscripciones en tu iPhone o iPad.</string>
    <string name="settings_subscription_faq_cancel_answer_android">Sí, podés cancelar tu suscripción cuando quieras desde la configuración de tu cuenta de Google Play.</string>
    <string name="settings_subscription_faq_data_question">¿Qué pasa con mis datos si cancelo?</string>
    <string name="settings_subscription_faq_data_answer">Tus datos se mantienen, pero vas a tener acceso limitado según el plan Básico.</string>
    <string name="settings_subscription_faq_trial_question">¿Hay prueba gratuita?</string>
    <string name="settings_subscription_faq_trial_answer">Sí, el plan Pro incluye 14 días de prueba gratis. Se renueva automáticamente al precio del plan elegido a menos que canceles al menos 24 horas antes de que termine el período de prueba.</string>
    <string name="settings_subscription_faq_change_question">¿Puedo cambiar de plan?</string>
    <string name="settings_subscription_faq_change_answer">Sí, podés actualizar o degradar tu plan en cualquier momento.</string>
    <string name="settings_subscription_legal">La suscripción se renueva automáticamente. Podés cancelar en cualquier momento desde Google Play &gt; Suscripciones. Solennix es un producto de Creapolis.</string>
