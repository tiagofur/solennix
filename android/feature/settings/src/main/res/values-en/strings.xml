    <string name="settings_subscription_faq_title">Frequently asked questions</string>
    <string name="settings_subscription_faq_cancel_question">Can I cancel at any time?</string>
    <string name="settings_subscription_faq_cancel_answer_web">Yes, you can cancel your subscription anytime. Since you subscribed on the web, go to solennix.com &gt; Settings &gt; Subscription.</string>
    <string name="settings_subscription_faq_cancel_answer_ios">Yes, you can cancel your subscription anytime. Since you subscribed from iOS, open Settings &gt; your Apple ID &gt; Subscriptions on your iPhone or iPad.</string>
    <string name="settings_subscription_faq_cancel_answer_android">Yes, you can cancel your subscription anytime from your Google Play account settings.</string>
    <string name="settings_subscription_faq_data_question">What happens to my data if I cancel?</string>
    <string name="settings_subscription_faq_data_answer">Your data is kept, but your access will be limited according to the Basic plan.</string>
    <string name="settings_subscription_faq_trial_question">Is there a free trial?</string>
    <string name="settings_subscription_faq_trial_answer">Yes, the Pro plan includes a 14-day free trial. It renews automatically at the selected plan price unless you cancel at least 24 hours before the trial period ends.</string>
    <string name="settings_subscription_faq_change_question">Can I change plans?</string>
    <string name="settings_subscription_faq_change_answer">Yes, you can upgrade or downgrade your plan at any time.</string>
    <string name="settings_subscription_legal">The subscription renews automatically. You can cancel anytime from Google Play &gt; Subscriptions. Solennix is a Creapolis product.</string>
