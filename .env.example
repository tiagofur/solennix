# Configuración para Docker Compose
# Copia este archivo a .env para desarrollo local

# --- Backend ---
BACKEND_PORT=8080
DATABASE_URL=postgres://solennix_user:solennix_password@db:5432/solennix?sslmode=disable
BOOTSTRAP_ADMIN_EMAIL=tiagofur@gmail.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth Social (Backend) ---
GOOGLE_CLIENT_IDS=your-ios-id,your-android-id,your-web-id
APPLE_CLIENT_IDS=com.solennix.app,com.solennix.web

# --- Auth Social (Web Frontend) ---
VITE_GOOGLE_CLIENT_ID=your-web-id
VITE_APPLE_CLIENT_ID=com.solennix.web

# --- Firebase (Web Frontend) ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080/api
