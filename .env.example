# Solennix — Environment Configuration
# Copy to .env (or backend/.env for the backend-only setup) and fill in values.
# Docker Compose reads this file from the repo root.
#
# Secrets below MUST NOT be committed. Only `.env.example` (placeholders) is
# in git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend · Core ──────────────────────────────────────────────────────────
BACKEND_PORT=8080
PORT=8080
ENVIRONMENT=development
DATABASE_URL=postgres://solennix_user:solennix_password@db:5432/solennix?sslmode=disable
BOOTSTRAP_ADMIN_EMAIL=tiagofur@gmail.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
# TRUST_PROXY=true REQUIRED in production (behind nginx + Cloudflare) so rate
# limiter + client IP logging use the real client IP from X-Forwarded-For.
# Leave false for local dev (no proxy).
TRUST_PROXY=false

# ── Backend · JWT ───────────────────────────────────────────────────────────
# JWT_SECRET must be ≥32 bytes. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-byte-random-secret-value
JWT_EXPIRY_HOURS=24

# ── Backend · OAuth Social ──────────────────────────────────────────────────
# Comma-separated. Backend validates the `aud` claim against this allowlist.
GOOGLE_CLIENT_IDS=your-ios-client-id,your-android-client-id,your-web-client-id
APPLE_CLIENT_IDS=com.solennix.app,com.solennix.web

# Apple Sign In REST flow (web callback path). .p8 contents raw or base64.
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APPLE_REDIRECT_URI=https://api.solennix.com/api/auth/apple/callback

# ── Backend · Stripe (web subscriptions) ────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys + Products + Webhooks.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
# Optional: a specific Billing Portal configuration ID (bpc_...) — omit to
# use the default portal config on the Stripe account.
STRIPE_PORTAL_CONFIG_ID=

# ── Backend · RevenueCat (mobile IAP bridge) ────────────────────────────────
# REVENUECAT_WEBHOOK_SECRET = Authorization header value configured in RC
# webhook settings. REVENUECAT_API_KEY = secret REST key for server-side
# entitlement grants (different from the public app keys used by mobile).
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-auth-header-value
REVENUECAT_API_KEY=sk_...

# ── Backend · Email (Resend transactional provider) ─────────────────────────
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Solennix <noreply@solennix.com>

# ── Backend · Push Notifications ────────────────────────────────────────────
# FCM service account JSON. Paste raw JSON on a single line (escape newlines)
# or base64-encode the file contents.
FCM_CREDENTIALS_JSON={"type":"service_account",...}

# APNs token-based auth (.p8 file on disk).
APNS_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=T5SKULSP2M
APNS_BUNDLE_ID=com.creapolis.solennix
APNS_PRODUCTION=false

# ── Backend · Storage (uploads) ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
STORAGE_PROVIDER=local
# Fill these only when STORAGE_PROVIDER=s3 (also works for MinIO / DO Spaces).
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=uploads
S3_ENDPOINT=
S3_CDN_URL=

# ── Web Frontend · Auth Social (built into Vite bundle) ─────────────────────
VITE_GOOGLE_CLIENT_ID=your-web-client-id
VITE_APPLE_CLIENT_ID=com.solennix.web

# ── Web Frontend · Firebase (FCM for browser push) ──────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# ── Web Frontend · API & Docker ─────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080/api

# ── Observability · Sentry (errors + basic performance) ─────────────────────
# Free tier: 5k errors/mo, 10k performance units.
# Create 2 projects at sentry.io: one React, one Go. Paste each DSN below.
# Empty values disable Sentry (no-op init, no reporting).
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz  # backend project (solennix-backend)
SENTRY_TRACES_SAMPLE_RATE=0.1                     # 0.0–1.0; prod default 0.1, dev 1.0

VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz  # web project (solennix-web)

# ── Mobile (build-time secrets — NOT in this file) ──────────────────────────
# iOS  → ios/Config/Secrets.xcconfig (REVENUECAT_PUBLIC_API_KEY, appl_...)
# Android → app/build.gradle.kts reads REVENUECAT_API_KEY from env or
#           ~/.gradle/gradle.properties (goog_...).
