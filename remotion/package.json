{
  "name": "solennix-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render ClientTutorial out/client-tutorial.mp4",
    "render:gif": "remotion render ClientTutorial out/client-tutorial.gif --image-format=png",
    "render:product": "remotion render ProductTutorial out/product-tutorial.mp4",
    "render:product:gif": "remotion render ProductTutorial out/product-tutorial.gif --image-format=png",
    "render:cotizacion": "remotion render CotizacionTutorial out/cotizacion-tutorial.mp4",
    "render:cotizacion:gif": "remotion render CotizacionTutorial out/cotizacion-tutorial.gif --image-format=png",
    "render:all": "npm run render && npm run render:product && npm run render:cotizacion",
    "render:chaos": "remotion render ChaosToOrder-Reel out/chaos-to-order.mp4"
  },
  "dependencies": {
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/zod-types": "^4.0.456",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
