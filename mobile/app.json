{
  "expo": {
    "name": "Solennix",
    "slug": "solennix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "solennix",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.creapolis.solennix"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.creapolis.solennix"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "react-native-purchases"
    ],
    "extra": {
      "privacyPolicyUrl": "https://www.creapolis.dev/privacy",
      "termsUrl": "https://www.creapolis.dev/terms",
      "eas": {
        "projectId": "2e366ad9-407a-42e8-adc1-8ba184962f8b"
      }
    }
  }
}
