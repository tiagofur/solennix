# Server
PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/eventosapp?sslmode=disable

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY_HOURS=24

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@eventosapp.com
FRONTEND_URL=http://localhost:5173

# ─── Stripe (Web Subscriptions) ───────────────────────────────────────
# Get these from the Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The Price ID for the Pro plan (monthly or yearly) in Stripe
STRIPE_PRO_PRICE_ID=price_...
# Optional: Billing Portal configuration ID (bpc_...) from Stripe Dashboard
STRIPE_PORTAL_CONFIG_ID=

# ─── RevenueCat (Mobile IAP: Apple + Google) ──────────────────────────
# Set a strong secret and paste the same value in the RevenueCat Dashboard
# under: Project Settings > Webhooks > Authorization Header
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

